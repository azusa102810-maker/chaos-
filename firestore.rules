rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model (Open Mode)
    // ===============================================================
    
    // Helper Functions
    function isValidQuote(data) {
      return data.content is string && data.content.size() >= 1 && data.content.size() <= 1000 &&
             data.category in ['workplace', 'romance', 'slacking'] &&
             data.authorId is string &&
             data.createdAt is timestamp;
    }

    function isValidMessage(data) {
      return data.content is string && data.content.size() >= 1 && data.content.size() <= 200 &&
             data.color is string && data.color.matches("^#[0-9a-fA-F]{6}$") &&
             data.authorId is string &&
             data.createdAt is timestamp;
    }

    // Rules - Fully Public Read/Create with Validation
    match /quotes/{quoteId} {
      allow read: if true;
      allow create: if isValidQuote(request.resource.data);
      allow delete: if false; // Only admin via console
    }

    match /messages/{messageId} {
      allow read: if true;
      allow create: if isValidMessage(request.resource.data);
      allow delete: if false;
    }
  }
}
